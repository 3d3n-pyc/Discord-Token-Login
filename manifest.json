{
    "name": "Discord Token Login Extension",
    "description": "This extension allows you to log in to your Discord account using your token. It is designed for educational purposes only.",
    "version": "1.0",
    "manifest_version": 3,
    "browser_specific_settings": {
        "gecko": {
            "id": "discord-token-login@3d3n",
            "strict_min_version": "109.0"
        }
    },
    "permissions": [
        "activeTab",
        "scripting",
        "cookies"
    ],
    "host_permissions": [
        "https://discord.com/*"
    ],
    "action": {
        "default_popup": "src/popup.html",
        "default_icon": "assets/image.png"
    }
}
